#!/usr/bin/env bash
# Credential helper wrapper: gates write credentials behind TTY confirmation.
# For push (store/get after a push negotiation), requires /dev/tty.
# Delegates to gh auth git-credential for actual credential lookup.

# Read the credential protocol input from stdin
input=$(cat)

# Extract the operation (get/store/erase) from the first argument
operation="$1"

if [ "$operation" = "get" ]; then
  # Block if running inside a Copilot/AI agent session
  if [ -n "$COPILOT_CLI" ] || [ -n "$COPILOT_AGENT_SESSION_ID" ] || [ -n "$CODEX_CLI" ] || [ -n "$AIDER_RUNNING" ]; then
    echo "🚫 Push credential blocked: AI agent detected. Ask the human to push." >&2
    exit 1
  fi

  # Block if no TTY available (non-interactive automation)
  if ! : </dev/tty 2>/dev/null; then
    echo "🚫 Credential blocked: no interactive terminal detected." >&2
    exit 1
  fi
fi

# Delegate to the real credential helper
echo "$input" | /opt/homebrew/bin/gh auth git-credential "$operation"
