[user]
  name = Hans Kristian Flaatten
  email = hans.kristian.flaatten@nav.no
  signingkey = 08723031EA995A49

[core]
  trustctime = true
  autocrlf = false #true
  editor = nvim
  excludesfile = ~/.gitignore_global
	hooksPath = /Users/hans/.config/git/hooks
	pager = delta

[color]
  ui = true
  branch = auto
  diff = auto
  status = auto

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red
  new = cyan

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[credential]
	helper = osxkeychain

[push]
	default = simple
	rebase = true

[alias]
  lg = log --color --graph --format='%Cred%h%Creset %C(magenta)[%G?]%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset%(trailers:key=Co-authored-by,separator=%x20,valueonly)' --abbrev-commit
  s = status
  c = commit -vS
  p = add -p
  co = checkout
  br = branch

  amend = commit -vS --amend
  conflicts = diff --name-only --diff-filter=U
  last = log -1 HEAD
  pull = pull --ff-only
  rebase = rebase -vS
  staged = diff --staged
  supdate = git submodule foreach 'git fetch origin; git checkout $(git rev-parse --abbrev-ref HEAD); git reset --hard origin/$(git rev-parse --abbrev-ref HEAD); git submodule update --recursive; git clean -dfx'
  undo = reset --soft HEAD~
  unstage = reset HEAD --
  feature = "!bash -c \"git fetch; git checkout -b $1 ${2:-'origin/master'}\" -"
  publish = "!bash -c \"git push -u origin $(git rev-parse --abbrev-ref HEAD) 2>&1 >/dev/null | awk '/pull request/{getline; print \\$2; fflush()}' | xargs open -a ${1:-'Firefox Developer Edition'}\" -"
  unpublish = "!sh -c 'git push --delete origin $(git rev-parse --abbrev-ref HEAD --)' -"
  whois = "!sh -c 'git log -i -1 --pretty=\"format:%an <%ae>\n\" --author=\"$1\"' -"
  claim = "!f() { git rebase HEAD~${1:-1} --exec 'GIT_COMMITTER_DATE=\"$(git log -1 --format=%cI)\" git commit --amend -S --no-verify -m \"$(git log -1 --format=%B | grep -v \"^Co-authored-by:\")\"'; }; f"
	dft = !GIT_EXTERNAL_DIFF=difft git diff
	dfts = !GIT_EXTERNAL_DIFF=difft git diff --staged
	dftl = !GIT_EXTERNAL_DIFF=difft git log -p --ext-diff
	diffs = diff -c delta.side-by-side=true
	logs = log -p -c delta.side-by-side=true

[merge]
	conflictStyle = zdiff3

[help]
	autocorrect = 1
[url "https://github.com/"]
  insteadOf = git@github.com:

[pull]
	ff = only
	rebase = true
[init]
	defaultBranch = main
[fetch]
	prune = true
[diff]
	colorMoved = zebra
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	dark = true
